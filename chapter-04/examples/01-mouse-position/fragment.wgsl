// Chapter 4 Example 1: マウス位置の可視化
// マウスの座標を画面の色として表示するシェーダー

@fragment
fn fs_main(in: VertexOutput) -> @location(0) vec4<f32> {
    // マウスの正規化座標を取得（-1.0〜1.0の範囲）
    let mouse = MouseCoords();
    
    // マウス座標を色に変換
    // X座標（-1.0〜1.0）を赤成分（0.0〜1.0）に変換
    let red = (mouse.x + 1.0) * 0.5;
    
    // Y座標（-1.0〜1.0）を緑成分（0.0〜1.0）に変換
    let green = (mouse.y + 1.0) * 0.5;
    
    // 青成分は固定値（見やすさのため）
    let blue = 0.5;
    
    // 最終的な色を作成
    let color = vec3(red, green, blue);
    
    // 色空間を変換して出力
    return vec4(ToLinearRgb(color), 1.0);
}

// 期待される動作：
// - マウスを左に移動すると画面が暗くなる（赤成分が減る）
// - マウスを右に移動すると画面が赤くなる（赤成分が増える）  
// - マウスを下に移動すると画面の緑成分が減る
// - マウスを上に移動すると画面の緑成分が増える
// - 青成分は常に50%で固定