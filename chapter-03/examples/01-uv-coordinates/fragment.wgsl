// Chapter 3 Example 1: UV座標可視化
// 座標系の理解を深めるため、UV座標を色として表示

@fragment
fn fs_main(in: VertexOutput) -> @location(0) vec4<f32> {
    // 正規化座標を取得 (-1.0 〜 1.0)
    let uv = NormalizedCoords(in.position.xy);
    
    // X座標を赤成分、Y座標を緑成分に変換
    // -1.0〜1.0の範囲を0.0〜1.0の範囲に変換
    let color = vec3(
        (uv.x + 1.0) * 0.5,  // X座標: 左端=0.0, 中央=0.5, 右端=1.0
        (uv.y + 1.0) * 0.5,  // Y座標: 下端=0.0, 中央=0.5, 上端=1.0
        0.3                   // 青成分は固定値（見やすくするため）
    );
    
    return vec4(ToLinearRgb(color), 1.0);
}

// 結果の解釈:
// - 左下が暗い（赤=0.0, 緑=0.0）
// - 右下が赤い（赤=1.0, 緑=0.0）
// - 左上が緑色（赤=0.0, 緑=1.0）
// - 右上が黄色（赤=1.0, 緑=1.0）
// - 中央がグレー（赤=0.5, 緑=0.5）

