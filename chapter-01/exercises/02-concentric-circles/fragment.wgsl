// 演習 2: 同心円パターンを作る
// 目標: Chapter1基本技術の統合作品「太陽の輪」制作 - 第2段階  
// 段階目標: 前ステップの基本円に同心円による太陽の層構造を追加

@fragment
fn fs_main(in: VertexOutput) -> @location(0) vec4<f32> {
    // 【前ステップから継承】: UV座標と距離計算の基本設定
    let uv = NormalizedCoords(in.position.xy);
    let distance = length(uv);
    var color = vec3(0.0, 0.0, 0.2); // 背景: 深い宇宙色
    
    // 【新規追加】: 複数条件分岐による同心円レイヤー構造
    if distance < 0.25 {
        // 太陽の核心: 最も高温の白熱色
        color = vec3(1.0, 0.9, 0.7);
    } else if distance < 0.45 {
        // 太陽の中間層: 黄橙色
        color = vec3(1.0, 0.7, 0.2);
    } else if distance < 0.7 {
        // 太陽の外層: 温かいオレンジ色（前ステップの太陽本体を継承・細分化）
        color = vec3(1.0, 0.6, 0.0);
    }
    // 0.7以上は背景色（宇宙）
    
    return vec4(ToLinearRgb(color), 1.0);
}

