// Exercise 1 Solution: 好きな色の作成
// 基本色から中間色まで様々な色を作成する解答例

@fragment
fn fs_main(in: VertexOutput) -> @location(0) vec4<f32> {
    
    // 1-1. 基本色の例
    // let color = vec3(0.0, 1.0, 0.0);  // 1. 純粋な緑色
    // let color = vec3(0.0, 0.0, 1.0);  // 2. 純粋な青色
    // let color = vec3(1.0, 1.0, 0.0);  // 3. 黄色
    // let color = vec3(1.0, 0.0, 1.0);  // 4. マゼンタ
    // let color = vec3(0.0, 1.0, 1.0);  // 5. シアン
    
    // 1-2. 中間色の例
    // let color = vec3(1.0, 0.5, 0.0);  // 1. オレンジ色
    // let color = vec3(0.5, 0.0, 1.0);  // 2. 紫色
    // let color = vec3(1.0, 0.7, 0.8);  // 3. ピンク色
    
    // 1-3. 自由課題の例
    let color = vec3(0.2, 0.8, 0.6);  // 例: 爽やかなミントグリーン
    // let color = vec3(0.9, 0.6, 0.1);  // 例: 温かいゴールド
    // let color = vec3(0.3, 0.2, 0.7);  // 例: 深い紫
    
    return vec4(ToLinearRgb(color), 1.0);
}

// 各色の特徴:
// - 基本色: RGB成分のうち1-2成分が最大値(1.0)
// - 中間色: 複数成分の組み合わせで微妙な色合いを表現
// - パステルカラー: 全体的に高めの値で明るい色
// - 濃い色: 全体的に低めの値で深い色