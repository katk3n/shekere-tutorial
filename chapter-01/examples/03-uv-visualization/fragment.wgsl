// Chapter 1 Example 3: UV座標の可視化
// 概念: 座標値を色として表示することによるデバッグ技法
// 目標: UV座標系を視覚的に理解する

@fragment
fn fs_main(in: VertexOutput) -> @location(0) vec4<f32> {
    // 正規化座標を取得 (-1.0 〜 1.0の範囲)
    let uv = NormalizedCoords(in.position.xy);
    
    // 座標値をabs()で正の値に変換して可視化
    let color = vec3(
        abs(uv.x),  // X座標: 中央=0.0, 左右端=1.0
        abs(uv.y),  // Y座標: 中央=0.0, 上下端=1.0  
        0.3         // 青成分: 固定値で見やすく調整
    );
    
    return vec4(ToLinearRgb(color), 1.0);
}

// 学習ポイント:
// - abs(): 絶対値関数で負の値を正の値に変換
// - 座標値を色として表示するデバッグ手法
// - 中央(0,0)が最も暗く、端に向かって明るくなる

// 結果の解釈:
// 中央=黒(0,0,0.3), 右端=赤(1,0,0.3), 上端=緑(0,1,0.3), 右上角=黄(1,1,0.3)